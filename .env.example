# Required for Auth.js and database-backed sessions.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/stock_alerts

# Optional. Comma or newline-separated exact email addresses.
# Leave blank to allow any Google account with an email address.
ALLOWED_EMAILS=

# Market data provider. Currently supported: brapi.
MARKET_DATA_PROVIDER=brapi

# Required for brapi.dev tickers outside the unrestricted test set.
BRAPI_API_TOKEN=

# Alert email delivery. Currently supported: ses.
EMAIL_PROVIDER=ses
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ALERT_EMAIL_FROM=

# Required. Vercel Cron must call /api/cron/check-alerts with
# Authorization: Bearer $CRON_SECRET.
CRON_SECRET=
